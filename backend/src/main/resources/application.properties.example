spring.application.name=DATN
# Database connection
spring.datasource.url=jdbc:mysql://localhost:3306/vocab_learning?useSSL=false&serverTimezone=UTC
spring.datasource.username=root
spring.datasource.password=YOUR_PASSWORD_HERE
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

# Use manual SQL migrations; avoid Hibernate auto-DDL to prevent FK conflicts.
spring.jpa.hibernate.ddl-auto=none

server.port=8080

# Return concise API errors without stack traces.
server.error.include-stacktrace=never
server.error.include-message=always

# Optional: enable AI condensation + context meaning selection in reading dictionary lookup.
datn.ai.openai-api-key=YOUR_OPENAI_API_KEY
datn.ai.openai-model=gpt-4o-mini

# ZaloPay Sandbox configuration
zalopay.app-id=YOUR_APP_ID
zalopay.key1=YOUR_KEY1
zalopay.key2=YOUR_KEY2
zalopay.endpoint=https://sb-openapi.zalopay.vn/v2/create
zalopay.redirect-url=http://localhost:5173/payment-result

# Cloudinary config
cloudinary.cloud-name=YOUR_CLOUD_NAME
cloudinary.api-key=YOUR_API_KEY
cloudinary.api-secret=YOUR_API_SECRET

# File upload limits
spring.servlet.multipart.max-file-size=500MB
spring.servlet.multipart.max-request-size=500MB

# Tool paths (Update these to your local paths)
datn.tool.yt-dlp=path/to/yt-dlp.exe
datn.tool.ffmpeg=path/to/ffmpeg.exe
